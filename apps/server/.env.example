DATABASE_URL=postgresql://user:password@host:5432/beercraft
REDIS_URL=redis://localhost:6379
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=YourBotUsername        # без @, например BeerCraftBot
WEBHOOK_URL=https://your-domain.com/webhook   # только для прода; без этого — polling
WEBHOOK_SECRET=random_secret_string           # опционально, для защиты webhook
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_URL=https://your-domain.com     # фронт URL (для invite-ссылок)
